# Copy to ".env.production" on the server and fill in real values.
# Do NOT commit the real .env.production.

NODE_ENV=production

# Database — host "db" is the Postgres service from docker-compose.prod.yml.
# For a real deploy use a strong password and change it in BOTH places.
DATABASE_URL=postgresql://zodchie:zodchie@db:5432/zodchie

# Signs the admin session cookie. Generate one:
#   openssl rand -base64 32
SESSION_SECRET=change-me-to-a-long-random-string

# Admin password hash. Generate it locally:
#   npx tsx prisma/hash-password.ts <your-password>
# Paste the hash here AS-IS, keep the $ characters (env_file does not expand them).
ADMIN_PASSWORD_HASH=$2b$10$REPLACE_WITH_REAL_HASH

# Set to "true" ONLY for an HTTP-only test (no HTTPS) so the admin login cookie
# is accepted over http. Remove it once the site is behind HTTPS.
SESSION_COOKIE_INSECURE=true
