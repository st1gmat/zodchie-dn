DATABASE_URL="postgresql://zodchie:zodchie@localhost:5433/zodchie"
SESSION_SECRET="generate-with: openssl rand -base64 32"
# Run `npx tsx prisma/hash-password.ts <password>` and paste its output here.
# Note: escape every `$` in the bcrypt hash as `\$` — Next's env loader expands `$...`.
ADMIN_PASSWORD_HASH="generate-with: npx tsx prisma/hash-password.ts <password>"
